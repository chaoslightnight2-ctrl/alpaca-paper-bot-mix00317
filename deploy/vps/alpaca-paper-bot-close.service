[Unit]
Description=Alpaca Paper Bot close backup guard
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/alpaca-paper-bot
EnvironmentFile=/etc/alpaca-paper-bot.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/alpaca-paper-bot/.venv/bin/python /opt/alpaca-paper-bot/paper_bot.py --execute --auto-window --loop --max-minutes 135
TimeoutStartSec=3h
KillSignal=SIGINT
